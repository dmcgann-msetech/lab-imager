<Window x:Class="LabImager.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lab Imager Help Center"
        Height="760"
        Width="1080"
        MinHeight="560"
        MinWidth="820"
        WindowStartupLocation="CenterOwner"
        Background="#0B0F12"
        Foreground="#E5E7EB">

    <Border BorderBrush="#334155" BorderThickness="1" Background="#0B0F12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#101820" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="18,0">
                <TextBlock Text="Lab Imager Help Center"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="#E5E7EB"/>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="245"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#0F1720" BorderBrush="#334155" BorderThickness="0,0,1,0">
                    <ListBox x:Name="HelpNavigation"
                             Background="#0F1720"
                             Foreground="#E5E7EB"
                             BorderThickness="0"
                             FontSize="14"
                             SelectionChanged="HelpNavigation_SelectionChanged">
                        <ListBoxItem Content="About Lab Imager" Tag="ABOUT"/>

                        <ListBoxItem Content="Help Topics" Tag="HELP"/>
                        <ListBoxItem Content="User Guide" Tag="USERGUIDE"/>
                        <ListBoxItem Content="FAQ" Tag="FAQ"/>
                        <ListBoxItem Content="Keyboard Shortcuts" Tag="SHORTCUTS"/>
                        <ListBoxItem Content="Release Notes" Tag="RELEASE"/>
                    </ListBox>
                </Border>

                <Grid Grid.Column="1">
                    <Grid x:Name="DocumentPanel">
                        <FlowDocumentScrollViewer x:Name="DocumentViewer"
                                                  Background="#0B0F12"
                                                  Foreground="#E5E7EB"
                                                  Padding="28"
                                                  VerticalScrollBarVisibility="Auto"/>
                    </Grid>

                    <Grid x:Name="AboutPanel" Visibility="Collapsed" Background="#0B0F12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="32" HorizontalAlignment="Center" MaxWidth="720">
                                <Image x:Name="AboutLogo"
                                       Width="260"
                                       Height="180"
                                       Stretch="Uniform"
                                       Margin="0,10,0,18"/>

                                <TextBlock Text="Lab Imager"
                                           FontSize="30"
                                           FontWeight="SemiBold"
                                           Foreground="#E5E7EB"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="Version 1.0 Release Candidate"
                                           FontSize="15"
                                           Foreground="#38BDF8"
                                           HorizontalAlignment="Center"
                                           Margin="0,6,0,24"/>

                                <TextBlock Text="Windows-native microscope and HDMI capture workstation for electronics inspection, evidence capture, reporting, and recording workflows."
                                           FontSize="15"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Foreground="#CBD5E1"
                                           Margin="0,0,0,24"/>

                                <TextBlock Text="MSE McGann Systems Engineering"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#E5E7EB"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="Copyright © 2026. All Rights Reserved."
                                           FontSize="13"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"
                                           Margin="0,6,0,8"/>

                                <TextBlock HorizontalAlignment="Center"
                                           Margin="0,0,0,12"
                                           FontSize="14">
                                    <Hyperlink Click="WebsiteLink_Click">
                                        <Run Text="🌐 https://msetech.org"/>
                                    </Hyperlink>
                                </TextBlock>

                                <Button Content="View License"
                                        Width="130"
                                        Height="28"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,24"
                                        Background="Transparent"
                                        Foreground="#38BDF8"
                                        BorderBrush="#38BDF8"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Click="ViewLicenseButton_Click"/>
                                <Border BorderBrush="#334155"
                                        BorderThickness="1"
                                        Background="#101820"
                                        Padding="18"
                                        Margin="0,6,0,24"
                                        Width="560">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Product Name" Foreground="#94A3B8" Margin="0,0,12,8"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Lab Imager" Foreground="#E5E7EB" Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Version" Foreground="#94A3B8" Margin="0,0,12,8"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="1.0 Release Candidate" Foreground="#E5E7EB" Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Platform" Foreground="#94A3B8" Margin="0,0,12,8"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Windows 10 / Windows 11" Foreground="#E5E7EB" Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Framework" Foreground="#94A3B8" Margin="0,0,12,8"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text=".NET 8 Desktop / WPF" Foreground="#E5E7EB" Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Camera Framework" Foreground="#94A3B8" Margin="0,0,12,8"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="DirectShow" Foreground="#E5E7EB" Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="License" Foreground="#94A3B8" Margin="0,0,12,8"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="Proprietary Software" Foreground="#E5E7EB" Margin="0,0,0,8"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Company" Foreground="#94A3B8" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" Text="MSE McGann Systems Engineering" Foreground="#E5E7EB"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>

            <Border Grid.Row="2" Background="#101820" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="12">
                <Button Content="Close"
                        Width="110"
                        Height="30"
                        HorizontalAlignment="Right"
                        Background="#1E293B"
                        Foreground="#E5E7EB"
                        BorderBrush="#38BDF8"
                        BorderThickness="1"
                        Click="CloseButton_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>







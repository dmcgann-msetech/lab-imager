<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================== -->
    <!-- LAB IMAGER DARK THEME                                -->
    <!-- ===================================================== -->

    <!-- Core Backgrounds -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#111827"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrushColor" Color="#334155"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#94A3B8"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#2563EB"/>

    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>

</ResourceDictionary>
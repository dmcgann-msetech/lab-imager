                                <Border Grid.Row="36" Grid.Column="55" BorderBrush="#334155" BorderThickness="0,0,0.45,0.45" Opacity="0.38"/>
                                <Border Grid.Row="36" Grid.Column="56" BorderBrush="#334155" BorderThickness="0,0,0.45,0.45" Opacity="0.38"/>
                        </Grid>

                        <!-- ENGINEERING GRID -->
                        <Rectangle x:Name="EngineeringGridOverlay" Opacity="0.10" Visibility="Collapsed">
                            <Rectangle.Fill>
                                <DrawingBrush TileMode="Tile"
                                              Viewport="0,0,36,36"
                                              ViewportUnits="Absolute">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing>
                                            <GeometryDrawing.Pen>
                                                <Pen Brush="#0EA5E9" Thickness="0.25"/>
                                            </GeometryDrawing.Pen>
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <LineGeometry StartPoint="0,0" EndPoint="36,0"/>
                                                    <LineGeometry StartPoint="0,0" EndPoint="0,36"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- CORNER RETICLES -->
                        <Grid Margin="34">
                            <Path Stroke="#93C5FD"
                                  StrokeThickness="2.5"
                                  Opacity="0.90"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  Data="M 0 70 L 0 0 L 70 0"/>

                            <Path Stroke="#93C5FD"
                                  StrokeThickness="2.5"
                                  Opacity="0.90"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Top"
                                  Data="M 0 0 L 70 0 L 70 70"/>

                            <Path Stroke="#93C5FD"
                                  StrokeThickness="2.5"
                                  Opacity="0.90"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Bottom"
                                  Data="M 0 0 L 0 70 L 70 70"/>

                            <Path Stroke="#93C5FD"
                                  StrokeThickness="2.5"
                                  Opacity="0.90"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Bottom"
                                  Data="M 0 70 L 70 70 L 70 0"/>
                        </Grid>

                        <!-- CENTER TICK MARKS -->
                        <Grid Margin="70">
                            <Rectangle Width="3"
                                       Height="28"
                                       Fill="#93C5FD"
                                       Opacity="0.85"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"/>

                            <Rectangle Width="3"
                                       Height="28"
                                       Fill="#93C5FD"
                                       Opacity="0.85"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Bottom"/>

                            <Rectangle Width="24"
                                       Height="3"
                                       Fill="#93C5FD"
                                       Opacity="0.85"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"/>

                            <Rectangle Width="24"
                                       Height="3"
                                       Fill="#93C5FD"
                                       Opacity="0.85"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- CENTER CONTENT -->
                        <StackPanel x:Name="ViewportPlaceholder"
                                    Panel.ZIndex="5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                            <TextBlock Text="&#x1F52C;"
                                       FontSize="78"
                                       HorizontalAlignment="Center"
                                       Foreground="#64748B"
                                       Opacity="0.75"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="MICROSCOPE VIEWPORT"
                                       HorizontalAlignment="Center"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="#A5B4FC"
                                       Margin="0,0,0,0"/>

                            <TextBlock Text="Live View / Camera Feed Will Appear Here"
                                       HorizontalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#94A3B8"/>
                        </StackPanel>
                    </Grid>
                </Border>

                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,0"
                             Padding="10,4"
                            CornerRadius="12"
                            Background="#111820"
                            BorderBrush="#334155"
                            BorderThickness="1"
                            Panel.ZIndex="10">

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <Button x:Name="StartPreviewButton"
                                    Style="{StaticResource ViewportTransportButtonStyle}"
                                    Click="StartPreviewButton_Click"
                                    Content="▶  Start"
                                    ToolTip="Start preview"
                                    Background="#14532D"
                                    BorderBrush="#22C55E"/>

                            <Button x:Name="FreezePreviewButton"
                                    Style="{StaticResource ViewportTransportButtonStyle}"
                                    Click="FreezePreviewButton_Click"
                                    Content="❄  Freeze"
                                    ToolTip="Freeze / resume preview"
                                    Background="#92400E"
                                    BorderBrush="#F59E0B"
                                    IsEnabled="False"/>

                            <Button x:Name="StopPreviewButton"
                                    Style="{StaticResource ViewportTransportButtonStyle}"
                                    Click="StopPreviewButton_Click"
                                    Content="■  Stop"
                                    ToolTip="Stop preview"
                                    Background="#334155"
                                    BorderBrush="#64748B"/>

                            <Button x:Name="RecordPreviewButton"
                                    Style="{StaticResource ViewportTransportButtonStyle}"
                                    Content="⏺  Record"
                                    ToolTip="Recording planned for future milestone"
                                    Background="#450A0A"
                                    BorderBrush="#EF4444"
                                    IsEnabled="False"/>
                        </StackPanel>
                    </Border>

                <!-- RIGHT PANEL -->
                <Border Grid.Column="1"
                        CornerRadius="12"
                        Background="#111820"
                        BorderBrush="#334155"
                        BorderThickness="1">

                    <Grid Margin="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="42"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,0">

                                <TextBlock Text="&#x2697;"
                                           FontSize="34"
                                           Foreground="#0EA5E9"
                                           Margin="0,0,14,0"/>

                                <TextBlock Text="LAB SESSION"
                                           FontSize="23"
                                           FontWeight="Bold"
                                           Foreground="#E5E7EB"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Height="1"
                                    Background="#2A3440"
                                    Margin="0,0,0,0"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                            <ScrollViewer.Resources>
                                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ThinVerticalScrollBarStyle}"/>
                            </ScrollViewer.Resources>
                            <StackPanel>
                            <TextBlock Text="Project Name"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,0"/>

                            <TextBox Height="44"
                                     Margin="0,0,0,0"
                                     Background="#0B0F12"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#334155"
                                     FontSize="13"
                                     Padding="4,2"/>

                            <TextBlock Text="Board / Device"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,0"/>

                            <TextBox Height="44"
                                     Margin="0,0,0,0"
                                     Background="#0B0F12"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#334155"
                                     FontSize="13"
                                     Padding="4,2"/>

                            <TextBlock Text="Technician"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,0"/>

                            <TextBox Height="44"
                                     Margin="0,0,0,0"
                                     Background="#0B0F12"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#334155"
                                     FontSize="13"
                                     Padding="4,2"/>

                            <TextBlock Text="Source"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,0"/>

                            <ComboBox x:Name="CameraSelector" Style="{StaticResource ReadableDisabledComboBoxStyle}"
                                      SelectionChanged="CameraSelector_SelectionChanged"
                                      ItemContainerStyle="{StaticResource CameraComboBoxItemStyle}"
                                      Height="38"
                                      MaxDropDownHeight="190"
                                      Margin="0,0,0,0"
                                      Background="White"
                                      Foreground="Black"
                                      BorderBrush="#334155"
                                      FontSize="13"
                                      Padding="10"/>

                            <Button x:Name="SetDefaultCameraButton" Style="{StaticResource PillActionButtonStyle}"
                                    Click="SetDefaultCameraButton_Click"
                                    Content="Set Default"
                                    ToolTip="Set selected camera as default source"
                                    Height="36"
                                    Margin="0,0,0,0"
                                    Background="#171D24"
                                    Foreground="White"
                                    BorderBrush="#334155"
                                    FontSize="14"
                                    FontWeight="SemiBold"/>
<TextBlock x:Name="PreviewStatusText"
                                       Text="Preview Idle"
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       Margin="0,0,0,0"/>

                            <TextBlock Text="Notes"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,10,0,8"/>

                            <Border Background="#0B0F12"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="6">

                                <DockPanel>
                                    <Border DockPanel.Dock="Top"
                                            Height="76"
                                            Background="#171D24"
                                            BorderBrush="#334155"
                                            BorderThickness="0,0,0,1"
                                            Padding="6,5">

                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,4">
                                                <Button Foreground="Black" Content="↶" Width="24" Margin="0,0,4,0" ToolTip="Undo" Click="NotesUndoButton_Click"/>
                                                <Button Foreground="Black" Content="↷" Width="24" Margin="0,0,8,0" ToolTip="Redo" Click="NotesRedoButton_Click"/>

                                                <ComboBox x:Name="NotesFontSelector"
                                                          SelectionChanged="NotesFontSelector_SelectionChanged"
                                                          Foreground="Black"
                                                          Width="110"
                                                          Height="28"
                                                          SelectedIndex="0"
                                                          Margin="0,0,8,0">
                                                    <ComboBoxItem Content="Segoe UI" Foreground="Black"/>
                                                    <ComboBoxItem Content="Calibri" Foreground="Black"/>
                                                    <ComboBoxItem Content="Arial" Foreground="Black"/>
                                                    <ComboBoxItem Content="Verdana" Foreground="Black"/>
                                                    <ComboBoxItem Content="Tahoma" Foreground="Black"/>
                                                    <ComboBoxItem Content="Georgia" Foreground="Black"/>
                                                    <ComboBoxItem Content="Times New Roman" Foreground="Black"/>
                                                    <ComboBoxItem Content="Cambria" Foreground="Black"/>
                                                    <ComboBoxItem Content="Book Antiqua" Foreground="Black"/>
                                                    <ComboBoxItem Content="Garamond" Foreground="Black"/>
                                                    <ComboBoxItem Content="Consolas" Foreground="Black"/>
                                                    <ComboBoxItem Content="Courier New" Foreground="Black"/>
                                                </ComboBox>

                                                <Button Foreground="Black" Content="B" Width="28" Margin="0,0,4,0" FontWeight="Bold" Click="NotesBoldButton_Click"/>
                                                <Button Foreground="Black" Content="I" Width="28" Margin="0,0,4,0" FontStyle="Italic" Click="NotesItalicButton_Click"/>
                                                <Button Foreground="Black" Content="U" Width="28" Margin="0,0,4,0" Click="NotesUnderlineButton_Click"/>
                                                <Button x:Name="NotesColorButton" Foreground="Black" Content="A" Width="28" ToolTip="Choose text color" Click="NotesColorButton_Click">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="White" Tag="White" Click="NotesTextColorMenuItem_Click"/>
                                                            <MenuItem Header="Black" Tag="Black" Click="NotesTextColorMenuItem_Click"/>
                                                            <MenuItem Header="Gray" Tag="Gray" Click="NotesTextColorMenuItem_Click"/>
                                                            <MenuItem Header="Yellow" Tag="Gold" Click="NotesTextColorMenuItem_Click"/>
                                                            <MenuItem Header="Orange" Tag="Orange" Click="NotesTextColorMenuItem_Click"/>
                                                            <MenuItem Header="Red" Tag="Red" Click="NotesTextColorMenuItem_Click"/>
                                                            <MenuItem Header="Pink" Tag="HotPink" Click="NotesTextColorMenuItem_Click"/>
                                                            <MenuItem Header="Purple" Tag="MediumPurple" Click="NotesTextColorMenuItem_Click"/>
                                                            <MenuItem Header="Blue" Tag="DodgerBlue" Click="NotesTextColorMenuItem_Click"/>
                                                            <MenuItem Header="Cyan" Tag="Cyan" Click="NotesTextColorMenuItem_Click"/>
                                                            <MenuItem Header="Green" Tag="LimeGreen" Click="NotesTextColorMenuItem_Click"/>
                                                            <MenuItem Header="Brown" Tag="SaddleBrown" Click="NotesTextColorMenuItem_Click"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Foreground="Black" Content="Bullet" Width="48" Margin="0,0,4,0" ToolTip="Bulleted list" Click="NotesBulletButton_Click"/>
                                                <Button Foreground="Black" Content="Align" Width="48" Margin="0,0,4,0" ToolTip="Cycle paragraph alignment" Click="NotesAlignButton_Click"/>
                                                <Button Foreground="Black" Content="Outline" Width="58" Margin="0,0,4,0" ToolTip="Numbered outline" Click="NotesOutlineButton_Click"/>
                                                <Button Foreground="Black" Content="Indent" Width="48" ToolTip="Increase indent" Click="NotesIndentButton_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <RichTextBox x:Name="NotesEditor"
                                                 Height="190"
                                                 Background="#0B0F12"
                                                 Foreground="#E5E7EB"
                                                 CaretBrush="#E5E7EB"
                                                 BorderThickness="0"
                                                 FontSize="13"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Padding="10"/>
                                </DockPanel>
                            </Border>
                        </StackPanel>

                        </ScrollViewer>

                        <Button Grid.Row="2"
                                Click="CaptureScreenshotButton_Click"
                                Content="Capture"
                                ToolTip="Capture screenshot"
                                Height="40"
                                FontSize="15"
                                FontWeight="Bold"
                                Background="#171D24"
                                Foreground="White"
                                BorderBrush="#334155"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- STATUS BAR -->
            <Border Grid.Row="2"
                    Padding="0"
                    Margin="10,0,10,10"
                    CornerRadius="10"
                    Background="#111820"
                    BorderBrush="#2A3440"
                    BorderThickness="1">

                <Grid Margin="18,0">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text=""
                                   Foreground="#22C55E"
                                   FontSize="18"
                                   Margin="0,0,10,0"/>

                        <TextBlock Text="Ready"
                                   FontSize="14"
                                   Margin="0,0,24,0"/>

                        <TextBlock x:Name="CameraStatusText"
                                   Text="&#x1F4F7;  No Source Connected"
                                   FontSize="14"
                                   Foreground="#CBD5E1"
                                   Margin="0,0,24,0"/>

                        <TextBlock Text="&#x1F4C1;  No Project Loaded"
                                   FontSize="14"
                                   Foreground="#CBD5E1"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <TextBlock Text="&#x2699;"
                                   FontSize="20"
                                   Foreground="#0EA5E9"
                                   Margin="0,0,28,0"/>

                        <TextBlock Text="?"
                                   FontSize="18"
                                   Foreground="#0EA5E9"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>






























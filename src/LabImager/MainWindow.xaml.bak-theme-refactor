<Window x:Class="LabImager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        Title="Lab Imager"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0B0F12"
        Foreground="#E5E7EB">

    <Window.Resources>
        <Style x:Key="CameraComboBoxItemStyle"
               TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    
    <Style x:Key="ReadableDisabledButtonStyle" TargetType="Button">
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="1"/>
                <Setter Property="Foreground" Value="#CBD5E1"/>
                <Setter Property="Background" Value="#334155"/>
                <Setter Property="BorderBrush" Value="#64748B"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ReadableDisabledComboBoxStyle" TargetType="ComboBox">
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="1"/>
                <Setter Property="Foreground" Value="#CBD5E1"/>
                <Setter Property="Background" Value="#1E293B"/>
                <Setter Property="BorderBrush" Value="#64748B"/>
            </Trigger>
        </Style.Triggers>
    </Style>

        <Style x:Key="ThinVerticalScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Background" Value="#111820"/>
            <Setter Property="Foreground" Value="#0EA5E9"/>
        </Style>
        <Style x:Key="PillActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ReadableDisabledButtonStyle}">
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,4"/>
        </Style>

        <Style x:Key="ViewportTransportButtonStyle" TargetType="Button" BasedOn="{StaticResource ReadableDisabledButtonStyle}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#171D24"/>
            <Setter Property="BorderBrush" Value="#0EA5E9"/>
        </Style>
</Window.Resources>

    <Border BorderBrush="#2A3440"

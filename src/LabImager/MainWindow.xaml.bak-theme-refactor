                    BorderBrush="#334155"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid Margin="18,0">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="&#x1F52C;"
                                   FontSize="18"
                                   Margin="0,0,12,0"/>

                        <TextBlock Text="Lab Imager"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <Button Content="-"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="13"
                                Click="MinimizeButton_Click"/>

                        <Button Content="MAX"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"

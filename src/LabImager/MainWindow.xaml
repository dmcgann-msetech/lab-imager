<Window x:Class="LabImager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        Title="Lab Imager"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#020617"
        Foreground="#E5E7EB">

    <Window.Resources>
        <Style x:Key="CameraComboBoxItemStyle"
               TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    
    <Style x:Key="ReadableDisabledButtonStyle" TargetType="Button">
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="1"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="Background" Value="#334155"/>
                <Setter Property="BorderBrush" Value="#64748B"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ReadableDisabledComboBoxStyle" TargetType="ComboBox">
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="1"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#64748B"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</Window.Resources>

    <Border BorderBrush="#1D4ED8"
            BorderThickness="1"
            Background="#020617">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0"
                    Background="#0B2A5B"
                    BorderBrush="#2563EB"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid Margin="18,0">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="&#x1F52C;"
                                   FontSize="18"
                                   Margin="0,0,12,0"/>

                        <TextBlock Text="Lab Imager"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <Button Content="-"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="13"
                                Click="MinimizeButton_Click"/>

                        <Button Content="MAX"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                Click="MaximizeRestoreButton_Click"/>

                        <Button Content="X"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="18"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1"
                  Margin="14">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="430"/>
                </Grid.ColumnDefinitions>

                <!-- VIEWPORT -->
                <Border x:Name="ViewportSurface"
                        Grid.Column="0"
                        CornerRadius="14"
                        Background="#03101F"
                        BorderBrush="#2563EB"
                        BorderThickness="1"
                        Margin="0,0,14,0"
                        Padding="10,6">

                    <Grid ClipToBounds="True">

                        <!-- DIRECTSHOW PREVIEW HOST -->
                        <wfi:WindowsFormsHost x:Name="PreviewHost"
                                              Panel.ZIndex="1"
                                              Visibility="Collapsed"
                                              Margin="58,40,18,18"
                                              Background="#000000">
                            <wf:Panel x:Name="PreviewPanel"
                                      BackColor="Black"/>
                        </wfi:WindowsFormsHost>
                        <!-- WPF FRAME PREVIEW HOST -->
                        <Border x:Name="FramePreviewHost"
                                Panel.ZIndex="2"
                                Visibility="Collapsed"
                                Margin="58,40,18,18"
                                Background="#000000"
                                ClipToBounds="True">
                            <Image x:Name="FramePreviewImage"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"/>
                        </Border>
                        <!-- VIEWPORT COORDINATE OVERLAY -->
                        
                        

                        <!-- ENGINEERING GRID -->
                        <Rectangle x:Name="EngineeringGridOverlay" Opacity="0.10" Visibility="Collapsed">
                            <Rectangle.Fill>
                                <DrawingBrush TileMode="Tile"
                                              Viewport="0,0,36,36"
                                              ViewportUnits="Absolute">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing>
                                            <GeometryDrawing.Pen>
                                                <Pen Brush="#38BDF8" Thickness="0.25"/>
                                            </GeometryDrawing.Pen>
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <LineGeometry StartPoint="0,0" EndPoint="36,0"/>
                                                    <LineGeometry StartPoint="0,0" EndPoint="0,36"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- CORNER RETICLES -->
                        <Grid Margin="34">
                            <Path Stroke="#93C5FD"
                                  StrokeThickness="2.5"
                                  Opacity="0.90"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  Data="M 0 70 L 0 0 L 70 0"/>

                            <Path Stroke="#93C5FD"
                                  StrokeThickness="2.5"
                                  Opacity="0.90"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Top"
                                  Data="M 0 0 L 70 0 L 70 70"/>

                            <Path Stroke="#93C5FD"
                                  StrokeThickness="2.5"
                                  Opacity="0.90"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Bottom"
                                  Data="M 0 0 L 0 70 L 70 70"/>

                            <Path Stroke="#93C5FD"
                                  StrokeThickness="2.5"
                                  Opacity="0.90"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Bottom"
                                  Data="M 0 70 L 70 70 L 70 0"/>
                        </Grid>

                        <!-- CENTER TICK MARKS -->
                        <Grid Margin="70">
                            <Rectangle Width="3"
                                       Height="28"
                                       Fill="#93C5FD"
                                       Opacity="0.85"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"/>

                            <Rectangle Width="3"
                                       Height="28"
                                       Fill="#93C5FD"
                                       Opacity="0.85"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Bottom"/>

                            <Rectangle Width="24"
                                       Height="3"
                                       Fill="#93C5FD"
                                       Opacity="0.85"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"/>

                            <Rectangle Width="24"
                                       Height="3"
                                       Fill="#93C5FD"
                                       Opacity="0.85"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- CENTER CONTENT -->
                        <StackPanel x:Name="ViewportPlaceholder"
                                    Panel.ZIndex="5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                            <TextBlock Text="&#x1F52C;"
                                       FontSize="78"
                                       HorizontalAlignment="Center"
                                       Foreground="#64748B"
                                       Opacity="0.75"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="MICROSCOPE VIEWPORT"
                                       HorizontalAlignment="Center"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="#A5B4FC"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="Live View / Camera Feed Will Appear Here"
                                       HorizontalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#94A3B8"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RIGHT PANEL -->
                <Border Grid.Column="1"
                        CornerRadius="12"
                        Background="#07182D"
                        BorderBrush="#2563EB"
                        BorderThickness="1">

                    <Grid Margin="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="72"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,18">

                                <TextBlock Text="&#x2697;"
                                           FontSize="34"
                                           Foreground="#38BDF8"
                                           Margin="0,0,14,0"/>

                                <TextBlock Text="LAB SESSION"
                                           FontSize="23"
                                           FontWeight="Bold"
                                           Foreground="#E5E7EB"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Height="1"
                                    Background="#1D4ED8"
                                    Margin="0,0,0,18"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1">
                            <TextBlock Text="Project Name"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"
                                       Foreground="White"/>

                            <TextBox Height="44"
                                     Margin="0,0,0,18"
                                     Background="#020B18"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#2563EB"
                                     FontSize="13"
                                     Padding="10,6"/>

                            <TextBlock Text="Board / Device"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"
                                       Foreground="White"/>

                            <TextBox Height="44"
                                     Margin="0,0,0,18"
                                     Background="#020B18"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#2563EB"
                                     FontSize="13"
                                     Padding="10,6"/>

                            <TextBlock Text="Technician"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"
                                       Foreground="White"/>

                            <TextBox Height="44"
                                     Margin="0,0,0,18"
                                     Background="#020B18"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#2563EB"
                                     FontSize="13"
                                     Padding="10,6"/>

                            <TextBlock Text="Source"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"
                                       Foreground="White"/>

                            <ComboBox x:Name="CameraSelector" Style="{StaticResource ReadableDisabledComboBoxStyle}"
                                      SelectionChanged="CameraSelector_SelectionChanged"
                                      ItemContainerStyle="{StaticResource CameraComboBoxItemStyle}"
                                      MaxDropDownHeight="220"
                                      Margin="0,0,0,10"
                                      BorderBrush="#2563EB"
                                      FontSize="13"
                                      Height="38"
                                      IsEnabled="True"
                                      Background="White"
                                      Foreground="Black"
                                      Padding="10"/>

                            <Button x:Name="SetDefaultCameraButton" Style="{StaticResource ReadableDisabledButtonStyle}"
                                    Click="SetDefaultCameraButton_Click"
                                    Content="Set Selected Source as Default"
                                    Height="36"
                                    Margin="0,0,0,10"
                                    Background="#0B63F6"
                                    Foreground="White"
                                    BorderBrush="#38BDF8"
                                    FontSize="14"
                                    FontWeight="SemiBold"/>
<Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="StartPreviewButton" Style="{StaticResource ReadableDisabledButtonStyle}"
                                        Grid.Column="0"
                                        Click="StartPreviewButton_Click"
                                        Content="Start Preview"
                                        Height="34"
                                        Background="#14532D"
                                        Foreground="White"
                                        BorderBrush="#22C55E"
                                        FontSize="13"
                                        FontWeight="SemiBold"/>

                                <Button x:Name="StopPreviewButton" Style="{StaticResource ReadableDisabledButtonStyle}"
                                        Grid.Column="2"
                                        Click="StopPreviewButton_Click"
                                        Content="Stop Preview"
                                        Height="34"
                                        Background="#334155"
                                        Foreground="White"
                                        BorderBrush="#64748B"
                                        FontSize="13"
                                        FontWeight="SemiBold"/>
                            </Grid>

                            <TextBlock x:Name="PreviewStatusText"
                                       Text="Preview Idle"
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       Margin="0,0,0,18"/>

                            <TextBlock Text="Notes"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,10,0,8"
                                       Foreground="White"/>

                            <Border Background="#020B18"
                                    BorderBrush="#2563EB"
                                    BorderThickness="1"
                                    CornerRadius="6">

                                <DockPanel>
                                    <Border DockPanel.Dock="Top"
                                            Height="76"
                                            Background="#102A4C"
                                            BorderBrush="#2563EB"
                                            BorderThickness="0,0,0,1"
                                            Padding="6,5">

                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,4">
                                                <Button Foreground="Black" Content="U" Width="24" Margin="0,0,4,0"/>
                                                <Button Foreground="Black" Content="R" Width="24" Margin="0,0,8,0"/>

                                                <ComboBox Foreground="Black" Width="110"
                                                          Height="28"
                                                          SelectedIndex="0"
                                                          Margin="0,0,8,0">
                                                    <ComboBoxItem Content="Segoe UI" Foreground="Black"/>
                                                    <ComboBoxItem Content="Sans Serif" Foreground="Black"/>
                                                    <ComboBoxItem Content="Consolas" Foreground="Black"/>
                                                </ComboBox>

                                                <Button Foreground="Black" Content="B" Width="28" Margin="0,0,4,0" FontWeight="Bold"/>
                                                <Button Foreground="Black" Content="I" Width="28" Margin="0,0,4,0" FontStyle="Italic"/>
                                                <Button Foreground="Black" Content="-" Width="28" Margin="0,0,4,0"/>
                                                <Button Foreground="Black" Content="A" Width="28"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal">
                                                <Button Foreground="Black" Content="List" Width="34" Margin="0,0,4,0"/>
                                                <Button Foreground="Black" Content="Align" Width="48" Margin="0,0,4,0"/>
                                                <Button Foreground="Black" Content="1." Width="38" Margin="0,0,4,0"/>
                                                <Button Foreground="Black" Content="Tab" Width="34"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <RichTextBox Height="260"
                                                 BorderThickness="0"
                                                 FontSize="13"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Padding="10"
                                                 Foreground="#E5E7EB"
                                                 CaretBrush="#E5E7EB"
                                                 Background="#020B18"/>
                                </DockPanel>
                            </Border>
                        </StackPanel>

                        <Button Grid.Row="2"
                                Click="CaptureScreenshotButton_Click"
                                Content="&#x1F4F7;  Capture Screenshot"
                                Height="40"
                                FontSize="15"
                                FontWeight="Bold"
                                Background="#0B63F6"
                                Foreground="White"
                                BorderBrush="#38BDF8"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- STATUS BAR -->
            <Border Grid.Row="2"
                    Padding="0"
                    Margin="10,0,10,10"
                    CornerRadius="10"
                    Background="#07182D"
                    BorderBrush="#1D4ED8"
                    BorderThickness="1">

                <Grid Margin="18,0">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text=""
                                   Foreground="#22C55E"
                                   FontSize="18"
                                   Margin="0,0,10,0"/>

                        <TextBlock Text="Ready"
                                   FontSize="14"
                                   Margin="0,0,24,0"/>

                        <TextBlock x:Name="CameraStatusText"
                                   Text="&#x1F4F7;  No Source Connected"
                                   FontSize="14"
                                   Foreground="White"
                                   Margin="0,0,24,0"/>

                        <TextBlock Text="&#x1F4C1;  No Project Loaded"
                                   FontSize="14"
                                   Foreground="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <TextBlock Text="&#x2699;"
                                   FontSize="20"
                                   Foreground="#38BDF8"
                                   Margin="0,0,28,0"/>

                        <TextBlock Text="?"
                                   FontSize="18"
                                   Foreground="#38BDF8"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

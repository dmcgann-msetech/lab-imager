<Window x:Class="LabImager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lab Imager"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#020617"
        Foreground="#E5E7EB">

    <Window.Resources>
        <Style x:Key="CameraComboBoxItemStyle"
               TargetType="ComboBoxItem">
            <Setter Property="Foreground"
                    Value="Black"/>
            <Setter Property="Background"
                    Value="White"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#1D4ED8"
            BorderThickness="1"
            Background="#020617">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0"
                    Background="#0B2A5B"
                    BorderBrush="#2563EB"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid Margin="18,0">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="🔬"
                                   FontSize="18"
                                   Margin="0,0,12,0"/>

                        <TextBlock Text="Lab Imager"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <Button Content="—"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="13"
                                Click="MinimizeButton_Click"/>

                        <Button Content="□"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                Click="MaximizeRestoreButton_Click"/>

                        <Button Content="×"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="18"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1"
                  Margin="14">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="430"/>
                </Grid.ColumnDefinitions>

                <!-- VIEWPORT -->
                <Border Grid.Column="0"
                        CornerRadius="14"
                        Background="#03101F"
                        BorderBrush="#2563EB"
                        BorderThickness="1"
                        Margin="0,0,14,0"
                        Padding="12">

                    <Grid ClipToBounds="True">

                        <!-- ENGINEERING GRID -->
                        <Rectangle Opacity="0.10">
                            <Rectangle.Fill>
                                <DrawingBrush TileMode="Tile"
                                              Viewport="0,0,36,36"
                                              ViewportUnits="Absolute">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing>
                                            <GeometryDrawing.Pen>
                                                <Pen Brush="#38BDF8"
                                                     Thickness="0.25"/>
                                            </GeometryDrawing.Pen>
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <LineGeometry StartPoint="0,0"
                                                                  EndPoint="36,0"/>
                                                    <LineGeometry StartPoint="0,0"
                                                                  EndPoint="0,36"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- CORNER RETICLES -->
                        <Grid Margin="34">
                            <Path Stroke="#93C5FD"
                                  StrokeThickness="2.5"
                                  Opacity="0.90"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  Data="M 0 70 L 0 0 L 70 0"/>

                            <Path Stroke="#93C5FD"
                                  StrokeThickness="2.5"
                                  Opacity="0.90"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Top"
                                  Data="M 0 0 L 70 0 L 70 70"/>

                            <Path Stroke="#93C5FD"
                                  StrokeThickness="2.5"
                                  Opacity="0.90"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Bottom"
                                  Data="M 0 0 L 0 70 L 70 70"/>

                            <Path Stroke="#93C5FD"
                                  StrokeThickness="2.5"
                                  Opacity="0.90"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Bottom"
                                  Data="M 0 70 L 70 70 L 70 0"/>
                        </Grid>

                        <!-- CENTER TICK MARKS -->
                        <Grid Margin="70">
                            <Rectangle Width="3"
                                       Height="28"
                                       Fill="#93C5FD"
                                       Opacity="0.85"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"/>

                            <Rectangle Width="3"
                                       Height="28"
                                       Fill="#93C5FD"
                                       Opacity="0.85"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Bottom"/>

                            <Rectangle Width="24"
                                       Height="3"
                                       Fill="#93C5FD"
                                       Opacity="0.85"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"/>

                            <Rectangle Width="24"
                                       Height="3"
                                       Fill="#93C5FD"
                                       Opacity="0.85"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- CENTER CONTENT -->
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                            <TextBlock Text="🔬"
                                       FontSize="78"
                                       HorizontalAlignment="Center"
                                       Foreground="#64748B"
                                       Opacity="0.75"
                                       Margin="0,0,0,16"/>

                            <TextBlock Text="MICROSCOPE VIEWPORT"
                                       HorizontalAlignment="Center"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="#A5B4FC"
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="Live View / Camera Feed Will Appear Here"
                                       HorizontalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#94A3B8"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RIGHT PANEL -->
                <Border Grid.Column="1"
                        CornerRadius="12"
                        Background="#07182D"
                        BorderBrush="#2563EB"
                        BorderThickness="1">

                    <Grid Margin="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="72"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,18">

                                <TextBlock Text="⚗"
                                           FontSize="34"
                                           Foreground="#38BDF8"
                                           Margin="0,0,14,0"/>

                                <TextBlock Text="LAB SESSION"
                                           FontSize="23"
                                           FontWeight="Bold"
                                           Foreground="#E5E7EB"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Height="1"
                                    Background="#1D4ED8"
                                    Margin="0,0,0,18"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1">
                            <TextBlock Text="Project Name"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <TextBox Height="38"
                                     Margin="0,0,0,18"
                                     Background="#020B18"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#2563EB"
                                     FontSize="13"
                                     Padding="12"/>

                            <TextBlock Text="Board / Device"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <TextBox Height="38"
                                     Margin="0,0,0,18"
                                     Background="#020B18"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#2563EB"
                                     FontSize="13"
                                     Padding="12"/>

                            <TextBlock Text="Technician"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <TextBox Height="38"
                                     Margin="0,0,0,18"
                                     Background="#020B18"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#2563EB"
                                     FontSize="13"
                                     Padding="12"/>

                            <TextBlock Text="Camera"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <ComboBox x:Name="CameraSelector"
                                      SelectionChanged="CameraSelector_SelectionChanged"
                                      ItemContainerStyle="{StaticResource CameraComboBoxItemStyle}"
                                      Height="38"
                                      MaxDropDownHeight="220"
                                      Margin="0,0,0,10"
                                      Background="#020B18"
                                      Foreground="#E5E7EB"
                                      BorderBrush="#2563EB"
                                      FontSize="13"
                                      Padding="10"/>

                            <Button x:Name="SetDefaultCameraButton"
                                    Content="Set Selected Camera as Default"
                                    Height="36"
                                    Margin="0,0,0,18"
                                    Background="#0B63F6"
                                    Foreground="White"
                                    BorderBrush="#38BDF8"
                                    FontSize="14"
                                    FontWeight="SemiBold"/>

                            <TextBlock Text="Notes"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,10,0,8"/>

                            <Border Background="#020B18"
                                    BorderBrush="#2563EB"
                                    BorderThickness="1"
                                    CornerRadius="6">

                                <DockPanel>
                                    <Border DockPanel.Dock="Top"
                                            Height="76"
                                            Background="#102A4C"
                                            BorderBrush="#2563EB"
                                            BorderThickness="0,0,0,1"
                                            Padding="6,5">

                                        <StackPanel>
                                            <!-- TOP ROW -->
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,4">
                                                <Button Content="↶" Width="24" Margin="0,0,4,0"/>
                                                <Button Content="↷" Width="24" Margin="0,0,8,0"/>

                                                <ComboBox Width="110"
                                                          Height="28"
                                                          SelectedIndex="0"
                                                          Margin="0,0,8,0">
                                                    <ComboBoxItem Content="Segoe UI" Foreground="Black"/>
                                                    <ComboBoxItem Content="Sans Serif" Foreground="Black"/>
                                                    <ComboBoxItem Content="Consolas" Foreground="Black"/>
                                                </ComboBox>

                                                <Button Content="B" Width="28" Margin="0,0,4,0" FontWeight="Bold"/>
                                                <Button Content="I" Width="28" Margin="0,0,4,0" FontStyle="Italic"/>
                                                <Button Content="U" Width="28" Margin="0,0,4,0"/>
                                                <Button Content="A" Width="28"/>
                                            </StackPanel>

                                            <!-- SECOND ROW -->
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="☰" Width="34" Margin="0,0,4,0"/>
                                                <Button Content="•" Width="34" Margin="0,0,4,0"/>
                                                <Button Content="1." Width="38" Margin="0,0,4,0"/>
                                                <Button Content="⇥" Width="34"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <RichTextBox Height="260"
                                                 Background="#020B18"
                                                 Foreground="#E5E7EB"
                                                 BorderThickness="0"
                                                 FontSize="13"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Padding="10"/>
                                </DockPanel>
                            </Border>
                        </StackPanel>

                        <Button Grid.Row="2"
                                Content="📷  Capture Screenshot"
                                Height="40"
                                FontSize="15"
                                FontWeight="Bold"
                                Background="#0B63F6"
                                Foreground="White"
                                BorderBrush="#38BDF8"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- STATUS BAR -->
            <Border Grid.Row="2"
                    Padding="0"
                    Margin="10,0,10,10"
                    CornerRadius="10"
                    Background="#07182D"
                    BorderBrush="#1D4ED8"
                    BorderThickness="1">

                <Grid Margin="18,0">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="●"
                                   Foreground="#22C55E"
                                   FontSize="18"
                                   Margin="0,0,10,0"/>

                        <TextBlock Text="Ready"
                                   FontSize="14"
                                   Margin="0,0,24,0"/>

                        <TextBlock x:Name="CameraStatusText"
                                   Text="📷  No Camera Connected"
                                   FontSize="14"
                                   Foreground="#CBD5E1"
                                   Margin="0,0,24,0"/>

                        <TextBlock Text="📁  No Project Loaded"
                                   FontSize="14"
                                   Foreground="#CBD5E1"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <TextBlock Text="⚙"
                                   FontSize="20"
                                   Foreground="#38BDF8"
                                   Margin="0,0,28,0"/>

                        <TextBlock Text="?"
                                   FontSize="18"
                                   Foreground="#38BDF8"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

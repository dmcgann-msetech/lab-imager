<Window x:Class="LabImager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lab Imager"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#020617"
        Foreground="#E5E7EB">

    <Border BorderBrush="#1D4ED8"
            BorderThickness="1"
            Background="#020617">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="54"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0"
                    Background="#0B2A5B"
                    BorderBrush="#2563EB"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid Margin="18,0">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="🔬"
                                   FontSize="22"
                                   Margin="0,0,12,0"/>

                        <TextBlock Text="Lab Imager"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <Button Content="—"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="18"
                                Click="MinimizeButton_Click"/>

                        <Button Content="□"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="16"
                                Click="MaximizeRestoreButton_Click"/>

                        <Button Content="×"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="22"
                                Click="CloseButton_Click"/>

                    </StackPanel>

                </Grid>

            </Border>

            <!-- Main Work Area -->
            <Grid Grid.Row="1"
                  Margin="14">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="430"/>
                </Grid.ColumnDefinitions>

                <!-- Viewport -->
                <Border Grid.Column="0"
                        CornerRadius="12"
                        Background="#061426"
                        BorderBrush="#2563EB"
                        BorderThickness="1"
                        Margin="0,0,14,0">

                    <Grid>

                        <TextBlock Text="🔬"
                                   FontSize="70"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,-120,0,0"
                                   Foreground="#64748B"
                                   Opacity="0.75"/>

                        <TextBlock Text="MICROSCOPE VIEWPORT"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#93A4C4"
                                   Margin="0,20,0,0"/>

                        <TextBlock Text="Live View / Camera Feed Will Appear Here"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   Foreground="#93A4C4"
                                   Margin="0,82,0,0"/>

                    </Grid>

                </Border>

                <!-- Right Dock -->
                <Border Grid.Column="1"
                        CornerRadius="12"
                        Background="#07182D"
                        BorderBrush="#2563EB"
                        BorderThickness="1">

                    <Grid Margin="24">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="72"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,18">

                                <TextBlock Text="⚗"
                                           FontSize="34"
                                           Foreground="#38BDF8"
                                           Margin="0,0,14,0"/>

                                <TextBlock Text="LAB SESSION"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="#E5E7EB"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                            <Border Height="1"
                                    Background="#1D4ED8"
                                    Margin="0,0,0,18"/>

                        </StackPanel>

                        <StackPanel Grid.Row="1">

                            <TextBlock Text="Project Name"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <TextBox Height="46"
                                     Margin="0,0,0,18"
                                     Background="#020B18"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#2563EB"
                                     FontSize="15"
                                     Padding="12"/>

                            <TextBlock Text="Board / Device"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <TextBox Height="46"
                                     Margin="0,0,0,18"
                                     Background="#020B18"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#2563EB"
                                     FontSize="15"
                                     Padding="12"/>

                            <TextBlock Text="Technician"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <TextBox Height="46"
                                     Margin="0,0,0,18"
                                     Background="#020B18"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#2563EB"
                                     FontSize="15"
                                     Padding="12"/>

                            <TextBlock Text="Notes"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <TextBox Height="190"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#020B18"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#2563EB"
                                     FontSize="15"
                                     Padding="12"/>

                        </StackPanel>

                        <Button Grid.Row="2"
                                Content="📷  Capture Screenshot"
                                Height="58"
                                FontSize="20"
                                FontWeight="Bold"
                                Background="#0B63F6"
                                Foreground="White"
                                BorderBrush="#38BDF8"/>

                    </Grid>

                </Border>

            </Grid>

            <!-- Bottom Status Bar -->
            <Border Grid.Row="2"
                    Margin="10,0,10,10"
                    CornerRadius="10"
                    Background="#07182D"
                    BorderBrush="#1D4ED8"
                    BorderThickness="1">

                <Grid Margin="22,0">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="●"
                                   Foreground="#22C55E"
                                   FontSize="22"
                                   Margin="0,0,10,0"/>

                        <TextBlock Text="Ready"
                                   FontSize="16"
                                   Margin="0,0,36,0"/>

                        <TextBlock Text="📷  No Camera Connected"
                                   FontSize="16"
                                   Foreground="#CBD5E1"
                                   Margin="0,0,36,0"/>

                        <TextBlock Text="📁  No Project Loaded"
                                   FontSize="16"
                                   Foreground="#CBD5E1"/>

                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <TextBlock Text="⚙"
                                   FontSize="24"
                                   Foreground="#38BDF8"
                                   Margin="0,0,28,0"/>

                        <TextBlock Text="?"
                                   FontSize="22"
                                   Foreground="#38BDF8"/>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Border>

</Window>


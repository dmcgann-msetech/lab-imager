<Window x:Class="LabImager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        Title="Lab Imager"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#020617"
        Foreground="#E5E7EB">

    <Window.Resources>
        <Style x:Key="CameraComboBoxItemStyle"
               TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    
    <Style x:Key="ReadableDisabledButtonStyle" TargetType="Button">
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="1"/>
                <Setter Property="Foreground" Value="#CBD5E1"/>
                <Setter Property="Background" Value="#334155"/>
                <Setter Property="BorderBrush" Value="#64748B"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ReadableDisabledComboBoxStyle" TargetType="ComboBox">
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="1"/>
                <Setter Property="Foreground" Value="#CBD5E1"/>
                <Setter Property="Background" Value="#1E293B"/>
                <Setter Property="BorderBrush" Value="#64748B"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</Window.Resources>

    <Border BorderBrush="#1D4ED8"
            BorderThickness="1"
            Background="#020617">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Grid.Row="0"
                    Background="#0B2A5B"
                    BorderBrush="#2563EB"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <Grid Margin="18,0">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <TextBlock Text="&#x1F52C;"
                                   FontSize="18"
                                   Margin="0,0,12,0"/>

                        <TextBlock Text="Lab Imager"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <Button Content="-"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="13"
                                Click="MinimizeButton_Click"/>

                        <Button Content="MAX"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                Click="MaximizeRestoreButton_Click"/>

                        <Button Content="X"
                                Width="44"
                                Height="34"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="18"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1"
                  Margin="14">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="430"/>
                </Grid.ColumnDefinitions>

